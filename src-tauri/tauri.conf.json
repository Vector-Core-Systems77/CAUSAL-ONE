{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CAUSAL-ONE",
  "version": "0.1.0",
  "identifier": "com.causal.one.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CAUSAL-ONE",
        "width": 1200,
        "height": 800
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "android": {
      "minSdkVersion": 24
    }
  }
}
