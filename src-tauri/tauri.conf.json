{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CAUSAL-ONE",
  "version": "0.1.0",
  "identifier": "com.causal.one",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CAUSAL-ONE",
        "width": 390,
        "height": 844,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false
  }
}
