{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Causal One",
  "version": "0.1.0",
  "identifier": "com.causalone.mobile",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "width": 800,
        "height": 600
      }
    ]
  },
  "plugins": {
    "shell": {}
  },
  "tauri": {
    "bundle": {
      "active": true,
      "targets": "all",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "android": {
      "package": "com.causalone.mobile",
      "minSdkVersion": 24
    }
  }
}
