{
  "$schema": "https://schema.tauri.app/config/v2",
  "productName": "CAUSAL-ONE",
  "version": "0.1.0",
  "identifier": "com.causalone.app",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "CAUSAL-ONE",
        "width": 400,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png"],
    "category": "DeveloperTool"
  },
  "plugins": {}
}
